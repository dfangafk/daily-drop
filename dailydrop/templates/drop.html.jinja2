<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily Drop — {{ date }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; background: #FFFFFF; margin: 0; padding: 0; color: #0F172A; }
    .wrapper { max-width: 620px; margin: 0 auto; background: #FFFFFF; }
    .header { border-bottom: 2px solid #E2E8F0; padding: 28px 32px 20px; text-align: center; }
    .header h1 { margin: 0; font-size: 22px; letter-spacing: -0.3px; color: #0F172A; font-weight: 700; }
    .header p { margin: 6px 0 0; font-size: 13px; color: #475569; letter-spacing: 0.3px; }
    .body { padding: 12px 32px; }
    .section-title { font-size: 11px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.6px; margin: 0 0 12px; }
    .find { border-bottom: 1px solid #E2E8F0; padding: 14px 0; }
    .find:last-child { border-bottom: none; }
    .find-title { font-size: 15px; font-weight: 600; line-height: 1.4; margin: 0 0 4px; }
    .find-byline { font-size: 11px; color: #6B7280; margin: 0 0 6px; }
    .find-title a { color: #1A1A1A; text-decoration: none; }
    .find-desc { font-size: 13px; color: #222222; line-height: 1.5; margin: 0 0 8px; }
    .find-thumb { display: block; margin: 8px auto 4px; width: 100%; max-width: 320px; }
    .find-thumb img { width: 100%; border-radius: 6px; display: block; }
    .footer { border-top: 1px solid #E2E8F0; padding: 10px 32px; font-size: 12px; color: #475569; text-align: center; line-height: 1.6; }
    .footer a { color: #2563EB; }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Header -->
    <div class="header">
      <h1>Daily Drop</h1>
      <p>{{ date }}</p>
    </div>

    <div class="body">
      <!-- All new finds -->
      {% if all_finds %}
{% for find in all_finds %}
      <div class="find">
        <p class="find-title"><a href="{{ find.url }}">{{ find.title }}</a></p>
        <p class="find-byline">by {{ find.source_name }}</p>
        {% if find.description %}<p class="find-desc">{{ find.description }}</p>{% endif %}
        {% if find.youtube_id %}
        <a href="{{ find.url }}" class="find-thumb">
          <img src="https://img.youtube.com/vi/{{ find.youtube_id }}/mqdefault.jpg" alt="Video preview — Enable image loading to view">
        </a>
        {% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>Daily Drop &mdash; your daily content digest</p>
    </div>
  </div>
</body>
</html>
