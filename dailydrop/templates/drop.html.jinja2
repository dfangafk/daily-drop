<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily Drop — {{ date }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; background: #FFFFFF; margin: 0; padding: 0; color: #0F172A; }
    .wrapper { max-width: 620px; margin: 0 auto; background: #FFFFFF; }
    .header { border-bottom: 2px solid #E2E8F0; padding: 28px 32px 20px; text-align: center; }
    .header h1 { margin: 0; font-size: 22px; letter-spacing: -0.3px; color: #0F172A; font-weight: 700; }
    .header p { margin: 6px 0 0; font-size: 13px; color: #475569; letter-spacing: 0.3px; }
    .body { padding: 12px 32px; }
    .section-title { font-size: 11px; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.6px; margin: 0 0 12px; }
    .item { border-bottom: 1px solid #E2E8F0; padding: 14px 0; }
    .item:last-child { border-bottom: none; }
    .item-header { display: table; width: 100%; margin-bottom: 6px; }
    .item-date { display: table-cell; font-size: 12px; color: #475569; }
    .item-link { display: table-cell; text-align: right; font-size: 12px; white-space: nowrap; }
    .item-link a { color: #2563EB; text-decoration: none; border-bottom: 1px solid #BFDBFE; }
    .item-title { font-size: 15px; font-weight: 600; line-height: 1.4; margin: 0 0 6px; color: #0F172A; }
    .pill { display: inline-block; background: #F1F5F9; color: #334155; font-size: 11px; padding: 2px 8px; border-radius: 10px; border: 1px solid #E2E8F0; }
    .item-desc { font-size: 13px; color: #475569; line-height: 1.5; margin: 0 0 8px; }
    .item-source { margin-top: 8px; }
    .item-thumb { display: block; margin: 8px auto 4px; width: 100%; max-width: 320px; }
    .item-thumb img { width: 100%; border-radius: 6px; display: block; }
    .footer { border-top: 1px solid #E2E8F0; padding: 10px 32px; font-size: 12px; color: #475569; text-align: center; line-height: 1.6; }
    .footer a { color: #2563EB; }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Header -->
    <div class="header">
      <h1>Daily Drop</h1>
      <p>{{ date }}</p>
    </div>

    <div class="body">
      <!-- All new items -->
      {% if all_items %}
{% for item in all_items %}
      <div class="item">
        <div class="item-header">
          {% if item.published_at %}<span class="item-date">{{ item.published_at.strftime('%b %-d, %Y, %-I:%M %p') }}</span>{% else %}<span class="item-date"></span>{% endif %}
          <span class="item-link"><a href="{{ item.url }}">View &rarr;</a></span>
        </div>
        <p class="item-title">{{ item.title }}</p>
        {% if item.description %}<p class="item-desc">{{ item.description }}</p>{% endif %}
        {% if item.youtube_id %}
        <a href="{{ item.url }}" class="item-thumb">
          <img src="https://img.youtube.com/vi/{{ item.youtube_id }}/mqdefault.jpg" alt="Video preview — Enable image loading to view">
        </a>
        {% endif %}
        <div class="item-source"><span class="pill">{{ item.source_name }}</span></div>
      </div>
      {% endfor %}
      {% endif %}
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>Daily Drop &mdash; your daily content digest</p>
    </div>
  </div>
</body>
</html>
