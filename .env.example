# Email
# Supported providers: gmail, outlook, yahoo, icloud, fastmail.
SENDER_EMAIL=
SMTP_PASSWORD=
# Can be the same as SENDER_EMAIL.
RECEIVER_EMAIL=

# SMTP (optional overrides)
# For custom SMTP servers (both must be set):
# NOTIFY__SMTP_HOST=smtp.example.com
# NOTIFY__SMTP_PORT=465

# Pipeline tuning
PIPELINE__LOG_LEVEL=INFO
