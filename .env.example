# LLM provider
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM__PROVIDER=auto
LLM__MODELS=["gemini/gemini-2.5-flash"]
LLM__TOP_N=5

# Email (Gmail SMTP)
SENDER_GMAIL=you@gmail.com
GMAIL_APP_PASSWORD=
RECEIVER_EMAIL=

# Pipeline tuning
PIPELINE__LOG_LEVEL=INFO
PIPELINE__ENABLE_LLM=true
PIPELINE__ENABLE_NOTIFY=true
PIPELINE__ENABLE_ARCHIVE=true
PIPELINE__SAVE_LOGS=true
