# Email
SENDER_EMAIL=you@example.com
SMTP_PASSWORD=
RECEIVER_EMAIL=

# SMTP settings are auto-detected from the SENDER_EMAIL domain.
# Supported providers: gmail, outlook, yahoo, icloud, fastmail.
#
# For custom domains (e.g. Google Workspace), set the provider explicitly:
# NOTIFY__EMAIL_PROVIDER=gmail
#
# To use any SMTP server directly (both must be set):
# NOTIFY__SMTP_HOST=smtp.example.com
# NOTIFY__SMTP_PORT=465

# Pipeline tuning
PIPELINE__LOG_LEVEL=INFO
